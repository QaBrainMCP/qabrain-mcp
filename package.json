{
  "name": "qabrain-mcp",
  "version": "1.1.1",
  "description": "AI-powered Browser Intelligence MCP Server for QA Automation",
  "author": "Soumya Ranjan Lenka",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/cli/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "qabrain-mcp": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QaBrainMCP/qabrain-mcp.git"
  },
  "homepage": "https://github.com/QaBrainMCP/qabrain-mcp",
  "bugs": {
    "url": "https://github.com/QaBrainMCP/qabrain-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ci": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=text-summary --coverage.reporter=html --coverage.reporter=json-summary",
    "verify:build": "node -e \"import('fs').accessSync('dist/index.js'); import('fs').accessSync('dist/cli/index.js'); console.log('Build verified');\"",
    "doctor": "node dist/cli/index.js doctor",
    "cli": "node dist/cli/index.js",
    "version:show": "node dist/cli/index.js version",
    "feature:learn": "tsx src/test/run-feature-learning.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "playwright",
    "qa",
    "automation",
    "browser",
    "typescript",
    "knowledge-graph"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.34.0",
    "license-checker": "^25.0.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  }
}
